    "technique": {
      "title": "High Jump Technique",
      "phases": [
        {
          "name": "Approach",
          "desc": "8-10 curved steps. Last 3 steps — increasing speed. Arc angle 30-45° to bar."
        },
        {
          "name": "Penultimate step",
          "desc": "Longer last step — center of mass lowers. Foot placed heel-first, roll."
        },
        {
          "name": "Takeoff",
          "desc": "Explosive extension at ankle, knee, hip. Swing free leg and arms upward."
        },
        {
          "name": "Flight (Fosbury Flop)",
          "desc": "Arch at lower back, clear bar sequentially: back → hips → legs."
        },
        {
          "name": "Landing",
          "desc": "On mat, back first. Delay leg extension until hips clear bar."
        }
      ]
    },
    "errors": {
      "title": "Common Errors",
      "items": [
        {
          "error": "Straight-line approach",
          "fix": "Start arc at step 4-5, gradually increase curve radius"
        },
        {
          "error": "Takeoff too far from bar",
          "fix": "Takeoff point 60-80 cm from bar projection"
        },
        {
          "error": "Weak arm swing",
          "fix": "Synchronized explosive arm drive upward at takeoff"
        },
        {
          "error": "Early back arch",
          "fix": "Arch only after shoulders have cleared bar"
        },
        {
          "error": "Bent legs in flop",
          "fix": "Extend legs upward after hips clear bar"
        }
      ]
    },
